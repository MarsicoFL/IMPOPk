# Build artifacts
**/target/
Cargo.lock

# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
.ipynb_checkpoints/

# IDE
.idea/
.vscode/
*.swp
*~

# OS
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp
*.log
*.out
*.aux

# ======================
# LARGE DATA FILES
# ======================

# Main experiment data (45+ GB)
experiments/chr1_full/data/*.tsv
experiments/chr1_full/data/partial_runs/

# Chr2 experiment data
experiments/chr2_50Mb_full/data/*.tsv
experiments/chr2_50Mb_filtered/data/*.tsv

# Full population data (6.8 GB)
experiments/full_population/**/*.tsv
experiments/full_population/**/*.txt
!experiments/full_population/**/README.md

# Benchmarks data
experiments/benchmarks/**/results/*.tsv
experiments/benchmarks/**/data/*.tsv

# Selection scan data
experiments/selection_scan/**/*.tsv

# External data symlinks (user must create these)
data/HPRC_r2_assemblies_0.6.1.agc
data/hprc465vschm13.aln.paf.gz
data/hprc465vschm13.aln.paf.gz.impg

# Large result files
**/*_combined.txt
**/figures/*.png
**/figures/*.pdf

# ======================
# KEEP (explicitly)
# ======================
# !experiments/**/README.md
# !experiments/**/scripts/
# !experiments/**/results/*.md
# !experiments/**/results/json/
